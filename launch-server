#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_DIR="$SCRIPT_DIR/backend"

cd "$BACKEND_DIR"

# Activate venv if it exists
if [ -d ".venv" ]; then
  source .venv/bin/activate
fi

# Ensure .env exists (copy from example if not)
if [ ! -f ".env" ] && [ -f "../.env.example" ]; then
  cp "../.env.example" ".env"
  echo "[launch-server] Created .env from .env.example"
fi

# Run migrations
echo "[launch-server] Running database migrations..."
alembic upgrade head

# Start uvicorn
echo "[launch-server] Starting uvicorn on http://localhost:8000..."
exec uvicorn api.main:app --reload --host 127.0.0.1 --port 8000
