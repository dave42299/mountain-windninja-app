# Database
DATABASE_URL=postgresql://windninja:windninja@localhost:5432/windninja

# Data storage (local path for terrain, weather, output files)
# DATA_DIR=./data

# WindNinja solver
# SOLVER_IMAGE=mountain-windninja:local
# SOLVER_THREADS=4

# Cloud storage (GCS or S3) -- Phase 4+
# STORAGE_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SRTM elevation data (for non-US terrain)
# CUSTOM_SRTM_API_KEY=your-opentopography-key

# Cesium Ion access token (for 3D terrain tiles in frontend)
# CESIUM_ION_TOKEN=your-token
