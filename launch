#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "==> Starting all services (Postgres + Backend + Frontend)..."
echo ""

# 1. Start Postgres via Docker Compose
echo "[1/3] Starting PostgreSQL..."
docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d
echo "      Waiting for Postgres to be healthy..."
until docker compose -f "$SCRIPT_DIR/docker-compose.yml" exec -T db pg_isready -U windninja > /dev/null 2>&1; do
  sleep 1
done
echo "      PostgreSQL is ready."
echo ""

# 2. Start backend
echo "[2/3] Starting backend (uvicorn on :8000)..."
"$SCRIPT_DIR/launch-server" &
SERVER_PID=$!
sleep 2
echo ""

# 3. Start frontend
echo "[3/3] Starting frontend (vite on :5173)..."
"$SCRIPT_DIR/launch-client" &
CLIENT_PID=$!
echo ""

echo "==> All services running:"
echo "    Frontend:  http://localhost:5173"
echo "    Backend:   http://localhost:8000"
echo "    Postgres:  localhost:5432"
echo ""
echo "Press Ctrl+C to stop all services."

cleanup() {
  echo ""
  echo "==> Shutting down..."
  kill "$CLIENT_PID" 2>/dev/null || true
  kill "$SERVER_PID" 2>/dev/null || true
  docker compose -f "$SCRIPT_DIR/docker-compose.yml" stop
  echo "    Done."
}
trap cleanup EXIT INT TERM

wait
